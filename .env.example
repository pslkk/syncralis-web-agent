# `node --env-file=.env bin/cli.js`.

# Minimum trust score (0-100) to auto-act (click/download) without asking. Lower = more autonomous, less safe.
SYNCRALIS_WEB_AGENT_TRUST_THRESHOLD=80

# Where verified downloads are saved.
SYNCRALIS_WEB_AGENT_DOWNLOAD_DIR=

# Max download size in bytes (default 50MB).
SYNCRALIS_WEB_AGENT_MAX_DOWNLOAD_BYTES=52428800

# Extra domains to always trust, comma-separated.
SYNCRALIS_WEB_AGENT_EXTRA_ALLOWLIST=

# Max parallel sub-agents in research_query.
SYNCRALIS_WEB_AGENT_CONCURRENCY=4

# Respect robots.txt (recommended: true).
SYNCRALIS_WEB_AGENT_RESPECT_ROBOTS_TXT=true

# Per-domain requests per minute before the agent backs off.
SYNCRALIS_WEB_AGENT_RATE_LIMIT_PER_DOMAIN_PER_MIN=20

# Circuit breaker: consecutive failures before pausing a domain, and cooldown.
SYNCRALIS_WEB_AGENT_CB_FAILURE_THRESHOLD=5
SYNCRALIS_WEB_AGENT_CB_COOLDOWN_MS=300000

# Structured audit log file (JSON Lines). Always also logged to stderr.
SYNCRALIS_WEB_AGENT_AUDIT_LOG_PATH=

# Redact query text in logs (useful if queries may contain sensitive info).
SYNCRALIS_WEB_AGENT_REDACT_QUERIES_IN_LOGS=false

# DANGER: only for testing against your own internal/staging targets.
SYNCRALIS_WEB_AGENT_ALLOW_PRIVATE_NETWORK_TARGETS=false

# DANGER: allow downloading macro-enabled Office formats (.docm/.xlsm/.pptm/
# .xlsb/.dotm/.xltm/.potm). These can run embedded VBA code on open and are
# a common real-world malware vector, so they're refused by default.
SYNCRALIS_WEB_AGENT_ALLOW_MACRO_OFFICE_DOWNLOADS=false

# DANGER: allow downloading files whose extension has no defined file-
# signature check (i.e. can't be verified as genuinely matching its claimed
# type). Plain-text formats (.txt/.csv/.json/.xml/.md) are always allowed
# regardless of this flag. Off by default: unverifiable files are refused.
SYNCRALIS_WEB_AGENT_ALLOW_UNVERIFIED_EXTENSIONS=false

# Outbound HTTP/HTTPS proxy for the browser (e.g. http://proxy.company.com:8080).
SYNCRALIS_WEB_AGENT_HTTP_PROXY=

# X (Twitter) API v2 bearer token — enables reliable official-API reads in fetch_updates.
SYNCRALIS_WEB_AGENT_X_BEARER_TOKEN=

# Instagram Graph API token + your connected Business/Creator account ID —
# enables Business Discovery reads of other public Business/Creator accounts.
SYNCRALIS_WEB_AGENT_INSTAGRAM_GRAPH_TOKEN=
SYNCRALIS_WEB_AGENT_INSTAGRAM_BUSINESS_ACCOUNT_ID=

# VirusTotal API key — enables an extra hash-reputation check on downloads.
SYNCRALIS_WEB_AGENT_VIRUSTOTAL_API_KEY=

# Per-navigation timeout in ms.
SYNCRALIS_WEB_AGENT_NAVIGATION_TIMEOUT_MS=20000
